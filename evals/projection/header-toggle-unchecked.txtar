Main section shown, mark-all toggle unchecked. The chevron is present (main is
shown) and bare (`#toggle-all` is not checked), so the header projects `v > ...`.
Pins: chevron shown + unchecked form. A completed todo is present so the footer
also shows the count and the Clear-completed segment, incidentally.

-- dom.html --
<section class="todoapp">
	<header class="header">
		<h1>todos</h1>
		<input class="new-todo" placeholder="What needs to be done?">
	</header>
	<section class="main">
		<input id="toggle-all" class="toggle-all" type="checkbox">
		<label for="toggle-all">Mark all as complete</label>
		<ul class="todo-list">
			<li data-id="t1">
				<div class="view">
					<input class="toggle" type="checkbox">
					<label>buy milk</label>
					<button class="destroy"></button>
				</div>
				<input class="edit" value="buy milk">
			</li>
			<li class="completed" data-id="t2">
				<div class="view">
					<input class="toggle" type="checkbox" checked>
					<label>walk the dog</label>
					<button class="destroy"></button>
				</div>
				<input class="edit" value="walk the dog">
			</li>
		</ul>
	</section>
	<footer class="footer">
		<span class="todo-count"><strong>1</strong> item left</span>
		<ul class="filters">
			<li><a class="selected" href="/">All</a></li>
			<li><a href="/active">Active</a></li>
			<li><a href="/completed">Completed</a></li>
		</ul>
		<button class="clear-completed">Clear completed</button>
	</footer>
</section>

-- projection.txt --
v > ""
#t1 [ ] buy milk
#t2 [x] ~walk the dog~
-- **1** item left | (All) Active Completed | [Clear completed]
