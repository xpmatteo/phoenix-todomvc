The label text carries the leading and trailing whitespace HTML rendering adds
(newlines and indentation), plus internal double spacing. The title is trimmed at
the ends but preserved inside, so this projects `[ ] buy   milk`. Contrast the
header value, which is quoted and verbatim (see `header-value-verbatim.txtar`).
Pins: item title read from the label, end-trimmed, internal whitespace kept.

-- dom.html --
<section class="todoapp">
	<header class="header">
		<h1>todos</h1>
		<input class="new-todo" placeholder="What needs to be done?">
	</header>
	<section class="main">
		<input id="toggle-all" class="toggle-all" type="checkbox">
		<label for="toggle-all">Mark all as complete</label>
		<ul class="todo-list">
			<li data-id="t1">
				<div class="view">
					<input class="toggle" type="checkbox">
					<label>
						buy   milk
					</label>
					<button class="destroy"></button>
				</div>
				<input class="edit" value="buy   milk">
			</li>
		</ul>
	</section>
	<footer class="footer">
		<span class="todo-count"><strong>1</strong> item left</span>
		<ul class="filters">
			<li><a class="selected" href="/">All</a></li>
			<li><a href="/active">Active</a></li>
			<li><a href="/completed">Completed</a></li>
		</ul>
	</footer>
</section>

-- projection.txt --
v > ""
#t1 [ ] buy   milk
-- **1** item left | (All) Active Completed
